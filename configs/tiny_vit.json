{
  "experiment": "tiny_vit",
  "seed": 42,
  "model": {
    "name": "tiny_vit",
    "num_classes": 100,
    "image_size": 32,
    "patch_size": 4,
    "embed_dim": 320,
    "depth": 8,
    "num_heads": 5,
    "mlp_ratio": 4.0,
    "dropout": 0.10,
    "pool": "cls"
  },
  "training": {
    "epochs": 160,
    "batch_size": 128,
    "num_workers": 4,
    "val_size": 5000,
    "lr": 0.001,
    "min_lr": 0.000001,
    "weight_decay": 0.05,
    "label_smoothing": 0.10,
    "augment": true,
    "randaugment": true
  }
}
