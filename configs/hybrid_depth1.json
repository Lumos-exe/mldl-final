{
  "experiment": "hybrid_depth1",
  "seed": 42,
  "model": {
    "name": "hybrid",
    "num_classes": 100,
    "stem_width": 48,
    "embed_dim": 128,
    "patch_size": 4,
    "depth": 1,
    "num_heads": 4,
    "mlp_ratio": 2.0,
    "dropout": 0.10,
    "feature_size": 16
  },
  "training": {
    "epochs": 80,
    "batch_size": 128,
    "num_workers": 4,
    "lr": 0.0007,
    "min_lr": 0.000001,
    "weight_decay": 0.04,
    "label_smoothing": 0.10,
    "augment": true,
    "randaugment": true
  }
}
