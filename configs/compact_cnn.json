{
  "experiment": "compact_cnn",
  "seed": 42,
  "model": {
    "name": "resnet18_cifar",
    "num_classes": 100,
    "base_width": 32,
    "dropout": 0.10
  },
  "training": {
    "epochs": 160,
    "batch_size": 128,
    "num_workers": 4,
    "val_size": 5000,
    "lr": 0.001,
    "min_lr": 0.000001,
    "weight_decay": 0.05,
    "label_smoothing": 0.10,
    "augment": true,
    "randaugment": true
  }
}
