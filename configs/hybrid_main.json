{
  "experiment": "hybrid_main",
  "seed": 42,
  "model": {
    "name": "resnet_hybrid",
    "num_classes": 100,
    "base_width": 52,
    "embed_dim": 208,
    "patch_size": 2,
    "depth": 4,
    "num_heads": 4,
    "mlp_ratio": 4.0,
    "dropout": 0.10,
    "feature_size": 8
  },
  "training": {
    "epochs": 160,
    "batch_size": 128,
    "num_workers": 4,
    "val_size": 5000,
    "lr": 0.001,
    "min_lr": 0.000001,
    "weight_decay": 0.05,
    "label_smoothing": 0.10,
    "augment": true,
    "randaugment": true
  }
}
